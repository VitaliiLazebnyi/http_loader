#!/usr/bin/env ruby
# typed: false
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path('../lib', __dir__)) unless $LOAD_PATH.include?(File.expand_path('../lib', __dir__))
require 'keep_alive'
require 'optparse'

command = ARGV.shift

case command
when 'client'
  options = {
    connections: 1000,
    use_https: false,
    target_urls: [],
    verbose: false,
    ping: true,
    ping_period: 5,
    keep_alive_timeout: 0.0,
    connections_per_second: 0,
    max_concurrent_connections: nil,
    reopen_closed_connections: false,
    reopen_interval: 5.0,
    read_timeout: 0.0,
    user_agent: 'Keep-Alive Test',
    ramp_up: 0.0,
    bind_ips: [],
    proxy_pool: [],
    qps_per_connection: 0,
    headers: {},
    slowloris_delay: 0.0
  }

  OptionParser.new do |opts|
    opts.banner = 'Usage: keep_alive client [options]'

    opts.on('--connections_count=COUNT', Integer, 'Total connections per session') { |v| options[:connections] = v }
    opts.on('--https', 'Use HTTPS natively') { options[:use_https] = true }
    opts.on('--url=URL', String, 'Target external URLs (comma separated)') { |v| options[:target_urls] = v.split(',') }
    opts.on('--verbose', 'Verbose logging') { options[:verbose] = true }
    opts.on('--[no-]ping', 'Ping connections to keep alive (default: true)') { |v| options[:ping] = v }
    opts.on('--ping_period=SECONDS', Integer, 'Ping period') { |v| options[:ping_period] = v }
    opts.on('--keep_alive_timeout=SECONDS', Float, 'Keep-alive timeout (0 for unlimited)') { |v| options[:keep_alive_timeout] = v }
    opts.on('--connections_per_second=RATE', Integer, 'Connections per second (0 for unlimited)') { |v| options[:connections_per_second] = v }
    opts.on('--max_concurrent_connections=COUNT', Integer, 'Max concurrent connections') { |v| options[:max_concurrent_connections] = v }
    opts.on('--reopen_closed_connections', 'Reopen closed connections') { options[:reopen_closed_connections] = true }
    opts.on('--reopen_interval=SECONDS', Float, 'Delay before reopening') { |v| options[:reopen_interval] = v }
    opts.on('--read_timeout=SECONDS', Float, 'Read timeout (0 for unlimited)') { |v| options[:read_timeout] = v }
    opts.on('--user_agent=AGENT', String, 'User Agent') { |v| options[:user_agent] = v }
    opts.on('--jitter=FACTOR', Float, 'Randomize sleep intervals') { |v| options[:jitter] = v }
    opts.on('--track_status_codes', 'Track specific HTTP status codes') { options[:track_status_codes] = true }
    opts.on('--ramp_up=SECONDS', Float, 'Smoothly scale traffic over seconds (overrides rate)') { |v| options[:ramp_up] = v }
    opts.on('--bind_ips=IPS', String, 'Comma-separated local IPs to bind to') { |v| options[:bind_ips] = v.split(',') }
    opts.on('--proxy_pool=URIS', String, 'Comma-separated proxy URIs to map sequentially') { |v| options[:proxy_pool] = v.split(',') }
    opts.on('--qps_per_connection=RATE', Integer, 'Active requests sent per second per payload') { |v| options[:qps_per_connection] = v }
    opts.on('--headers=LIST', String, 'Comma-separated headers') do |v|
      v.split(',').each do |pair|
        key, value = pair.split(':', 2)
        options[:headers][key.strip] = value.strip if key && value
      end
    end
    opts.on('--slowloris_delay=SECONDS', Float, 'Mathematical gap between byte payloads holding threads open') do |v|
      options[:slowloris_delay] = v
    end
    opts.on('--export_json=FILE', String) { nil }
    opts.on('--target_duration=SECONDS', Float) { nil }
  end.parse!(ARGV)

  options[:max_concurrent_connections] ||= options[:connections]
  options[:target_urls] ||= []
  options[:jitter] ||= 1.0
  options[:track_status_codes] ||= false

  begin
    config = KeepAlive::Client::Config.new(
      connections: options[:connections], target_urls: options[:target_urls], use_https: options[:use_https],
      verbose: options[:verbose], ping: options[:ping], ping_period: options[:ping_period],
      keep_alive_timeout: options[:keep_alive_timeout], connections_per_second: options[:connections_per_second],
      max_concurrent_connections: options[:max_concurrent_connections], reopen_closed_connections: options[:reopen_closed_connections],
      reopen_interval: options[:reopen_interval], read_timeout: options[:read_timeout], user_agent: options[:user_agent],
      jitter: options[:jitter], track_status_codes: options[:track_status_codes], ramp_up: options[:ramp_up],
      bind_ips: options[:bind_ips], proxy_pool: options[:proxy_pool], qps_per_connection: options[:qps_per_connection],
      headers: options[:headers], slowloris_delay: options[:slowloris_delay]
    )
    client = KeepAlive::Client.new(config)
    client.start
  rescue ArgumentError => e
    warn "Configuration Error: #{e.message}"
    exit(1)
  end

when 'server'
  use_https = ARGV.include?('--https')
  server = KeepAlive::Server.new
  server.start(use_https: use_https, port: use_https ? 8443 : 8080)

when 'harness'
  original_args = ARGV.dup
  options = { connections: 1000, use_https: false, target_urls: [], export_json: nil, target_duration: 0.0 }

  OptionParser.new do |opts|
    opts.banner = 'Usage: keep_alive harness [options]'

    opts.on('--connections_count=COUNT', Integer) { |v| options[:connections] = v }
    opts.on('--https') { options[:use_https] = true }
    opts.on('--url=URL', String) { |v| options[:target_urls] = v.split(',') }
    opts.on('--export_json=FILE', String) { |v| options[:export_json] = v }
    opts.on('--target_duration=SECONDS', Float) { |v| options[:target_duration] = v }

    # Ignore all other options (they belong to Client)
    opts.on('--verbose') { nil }
    opts.on('--[no-]ping') { nil }
    opts.on('--ping_period=SECONDS', Integer) { nil }
    opts.on('--keep_alive_timeout=SECONDS', Float) { nil }
    opts.on('--connections_per_second=RATE', Integer) { nil }
    opts.on('--max_concurrent_connections=COUNT', Integer) { nil }
    opts.on('--reopen_closed_connections') { nil }
    opts.on('--reopen_interval=SECONDS', Float) { nil }
    opts.on('--read_timeout=SECONDS', Float) { nil }
    opts.on('--user_agent=AGENT', String) { nil }
    opts.on('--jitter=FACTOR', Float) { nil }
    opts.on('--track_status_codes') { nil }
    opts.on('--ramp_up=SECONDS', Float) { nil }
    opts.on('--bind_ips=IPS', String) { nil }
    opts.on('--proxy_pool=URIS', String) { nil }
    opts.on('--qps_per_connection=RATE', Integer) { nil }
    opts.on('--headers=LIST', String) { nil }
    opts.on('--slowloris_delay=SECONDS', Float) { nil }
  end.parse!(ARGV)

  begin
    hconfig = KeepAlive::Harness::Config.new(
      connections: options[:connections],
      target_urls: options[:target_urls],
      use_https: options[:use_https],
      client_args: original_args,
      export_json: options[:export_json],
      target_duration: options[:target_duration]
    )
    harness = KeepAlive::Harness.new(hconfig)
    harness.start
  rescue ArgumentError => e
    warn "Configuration Error: #{e.message}"
    exit(1)
  end

else
  warn 'Usage: keep_alive <client|server|harness> [options]'
  exit(1)
end
